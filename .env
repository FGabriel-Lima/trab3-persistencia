# =============================================================================
# Sistema de Gerenciamento de Denúncias Urbanas — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores antes de executar.

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# URI local via Docker Compose (padrão):
MONGODB_URI=mongodb://mongo:27017

# URI Atlas (comente a linha acima e descomente abaixo para usar o Atlas):
# MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority

MONGODB_DATABASE=denuncias_urbanas

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=denuncias-bucket
# Use False dentro do Docker (HTTP). Mude para True em produção com HTTPS.
MINIO_SECURE=False

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_TITLE=Sistema de Denúncias Urbanas
API_VERSION=1.0.0
DEBUG=True
